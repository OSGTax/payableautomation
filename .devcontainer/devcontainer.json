{
  "name": "Payable Automation",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {},
  "forwardPorts": [5000],
  "portsAttributes": {
    "5000": {
      "label": "Payable Automation",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y poppler-utils && pip install -r requirements.txt",
  "postStartCommand": "nohup python run.py > /tmp/flask.log 2>&1 &",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  }
}
